<Window x:Class="Kurs.Views.Dialogs.AddServiceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить работу" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F0F0">
    <StackPanel Margin="20">
        <TextBlock Text="Добавить работу в наряд" FontSize="14" FontWeight="SemiBold"
                   Foreground="#1A1A1A" Margin="0,0,0,14"/>
        <TextBlock Text="Описание работы *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtDesc" Style="{StaticResource ModernTextBox}" Height="70"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalContentAlignment="Top" Padding="6,6"
                 VerticalScrollBarVisibility="Auto"/>
        <TextBlock Text="Стоимость *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtPrice" Style="{StaticResource ModernTextBox}" Height="28" Text="0"/>
        <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                        MinWidth="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Добавить" Style="{StaticResource SuccessButton}"
                        MinWidth="100" Click="BtnAdd_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
