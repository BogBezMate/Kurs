<Window x:Class="Kurs.Views.Dialogs.EmployeeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F0F0F0">
    <StackPanel Margin="20">
        <TextBlock x:Name="TxtTitle" FontSize="14" FontWeight="SemiBold"
                   Foreground="#1A1A1A" Margin="0,0,0,14"/>
        <TextBlock Text="Фамилия *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtLastName"   Style="{StaticResource ModernTextBox}" Height="28"/>
        <TextBlock Text="Имя *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtFirstName"  Style="{StaticResource ModernTextBox}" Height="28"/>
        <TextBlock Text="Отчество" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtMiddleName" Style="{StaticResource ModernTextBox}" Height="28"/>
        <TextBlock Text="Должность *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtPosition"   Style="{StaticResource ModernTextBox}" Height="28"/>
        <TextBlock Text="Телефон" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtPhone"      Style="{StaticResource ModernTextBox}" Height="28"/>
        <TextBlock Text="Email" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtEmail"      Style="{StaticResource ModernTextBox}" Height="28"/>
        <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                        MinWidth="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                        MinWidth="100" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
