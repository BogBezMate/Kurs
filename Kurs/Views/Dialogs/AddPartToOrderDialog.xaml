<Window x:Class="Kurs.Views.Dialogs.AddPartToOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить запчасть" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F0F0">
    <StackPanel Margin="20">
        <TextBlock Text="Добавить запчасть в наряд" FontSize="14" FontWeight="SemiBold"
                   Foreground="#1A1A1A" Margin="0,0,0,14"/>
        <TextBlock Text="Запчасть *" Style="{StaticResource FormLabel}"/>
        <ComboBox x:Name="CmbPart" Style="{StaticResource ModernComboBox}"
                  DisplayMemberPath="Name" SelectedValuePath="ID_Parts"
                  SelectionChanged="CmbPart_SelectionChanged"/>
        <TextBlock x:Name="LblInfo" FontSize="12" Foreground="#555555" Margin="0,6,0,0"/>
        <TextBlock Text="Количество *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtQuantity" Style="{StaticResource ModernTextBox}" Height="28" Text="1"/>
        <TextBlock Text="Цена за единицу *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtPrice" Style="{StaticResource ModernTextBox}" Height="28" Text="0"/>
        <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                        MinWidth="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Добавить" Style="{StaticResource SuccessButton}"
                        MinWidth="100" Click="BtnAdd_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
