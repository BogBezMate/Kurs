<Window x:Class="Kurs.Views.Dialogs.AssignEmployeeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Назначить сотрудника" Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F0F0">
    <StackPanel Margin="20">
        <TextBlock Text="Назначить исполнителя" FontSize="14" FontWeight="SemiBold"
                   Foreground="#1A1A1A" Margin="0,0,0,14"/>
        <TextBlock Text="Сотрудник *" Style="{StaticResource FormLabel}"/>
        <ComboBox x:Name="CmbEmployee" Style="{StaticResource ModernComboBox}"
                  DisplayMemberPath="FullName" SelectedValuePath="ID_Employees"/>
        <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                        MinWidth="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Назначить" Style="{StaticResource SuccessButton}"
                        MinWidth="100" Click="BtnAssign_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
