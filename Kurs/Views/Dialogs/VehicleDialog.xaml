<Window x:Class="Kurs.Views.Dialogs.VehicleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F0F0">
    <StackPanel Margin="20">
        <TextBlock x:Name="TxtTitle" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,14"/>
        <TextBlock Text="Клиент *" Style="{StaticResource FormLabel}"/>
        <ComboBox x:Name="CmbCustomer" Style="{StaticResource ModernComboBox}"
                  DisplayMemberPath="FullName" SelectedValuePath="ID_Customers"/>
        <TextBlock Text="VIN (17 символов) *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtVIN"   Style="{StaticResource ModernTextBox}" Height="28" MaxLength="17"/>
        <TextBlock Text="Госномер *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtPlate" Style="{StaticResource ModernTextBox}" Height="28"/>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Марка" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="TxtBrand" Style="{StaticResource ModernTextBox}" Height="28"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Модель" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="TxtModel" Style="{StaticResource ModernTextBox}" Height="28"/>
            </StackPanel>
        </Grid>
        <TextBlock Text="Год выпуска" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtYear" Style="{StaticResource ModernTextBox}" Height="28"/>
        <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                        MinWidth="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                        MinWidth="100" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
