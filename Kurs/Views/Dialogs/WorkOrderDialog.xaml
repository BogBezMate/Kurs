<Window x:Class="Kurs.Views.Dialogs.WorkOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F0F0">
    <StackPanel Margin="20">
        <TextBlock x:Name="TxtTitle" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,14"/>
        <TextBlock Text="Номер наряда *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtNumber" Style="{StaticResource ModernTextBox}" Height="28"/>
        <TextBlock Text="Клиент *" Style="{StaticResource FormLabel}"/>
        <ComboBox x:Name="CmbCustomer" Style="{StaticResource ModernComboBox}"
                  DisplayMemberPath="FullName" SelectedValuePath="ID_Customers"
                  SelectionChanged="CmbCustomer_SelectionChanged"/>
        <TextBlock Text="Автомобиль *" Style="{StaticResource FormLabel}"/>
        <ComboBox x:Name="CmbVehicle" Style="{StaticResource ModernComboBox}"
                  DisplayMemberPath="DisplayName" SelectedValuePath="ID_Vehicles"/>
        <TextBlock Text="Статус" Style="{StaticResource FormLabel}"/>
        <ComboBox x:Name="CmbStatus" Style="{StaticResource ModernComboBox}"/>
        <TextBlock Text="Примечания" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtNotes" Style="{StaticResource ModernTextBox}" Height="70"
                 TextWrapping="Wrap" AcceptsReturn="True"
                 VerticalContentAlignment="Top" Padding="6,6"
                 VerticalScrollBarVisibility="Auto"/>
        <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                        MinWidth="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                        MinWidth="100" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
