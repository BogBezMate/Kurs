<Window x:Class="Kurs.Views.Dialogs.PartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#F0F0F0">
    <StackPanel Margin="20">
        <TextBlock x:Name="TxtTitle" FontSize="14" FontWeight="SemiBold" Foreground="#1A1A1A" Margin="0,0,0,14"/>
        <TextBlock Text="Наименование *" Style="{StaticResource FormLabel}"/>
        <TextBox x:Name="TxtName" Style="{StaticResource ModernTextBox}" Height="28"/>
        <TextBlock Text="Поставщик" Style="{StaticResource FormLabel}"/>
        <ComboBox x:Name="CmbSupplier" Style="{StaticResource ModernComboBox}"
                  DisplayMemberPath="Name" SelectedValuePath="ID_Suppliers"/>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="10"/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Остаток" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="TxtQuantity" Style="{StaticResource ModernTextBox}" Height="28" Text="0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Цена *" Style="{StaticResource FormLabel}"/>
                <TextBox x:Name="TxtPrice" Style="{StaticResource ModernTextBox}" Height="28" Text="0"/>
            </StackPanel>
        </Grid>
        <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Margin="0,14,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Отмена" Style="{StaticResource SecondaryButton}"
                        MinWidth="80" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                        MinWidth="100" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Window>
