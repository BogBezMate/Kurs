<Page x:Class="Kurs.Views.Pages.VehiclesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F0F0">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="White" Padding="14,10"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Автомобили" Style="{StaticResource PageTitle}"/>
                    <TextBlock x:Name="TxtCount" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="Добавить" Style="{StaticResource PrimaryButton}"
                        Height="28" VerticalAlignment="Center" Click="BtnAdd_Click"/>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Top" Background="White" Padding="14,8"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <TextBox x:Name="TxtSearch" Style="{StaticResource ModernTextBox}"
                     Height="26" MaxWidth="320" HorizontalAlignment="Left"
                     TextChanged="TxtSearch_TextChanged"/>
        </Border>
        <DataGrid x:Name="GridVehicles" Style="{StaticResource ModernGrid}" Margin="12">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"        Binding="{Binding ID_Vehicles}"       Width="50"/>
                <DataGridTextColumn Header="Клиент"    Binding="{Binding Customer.FullName}"  Width="*"/>
                <DataGridTextColumn Header="Марка"     Binding="{Binding Brand}"              Width="100"/>
                <DataGridTextColumn Header="Модель"    Binding="{Binding Model}"              Width="100"/>
                <DataGridTextColumn Header="Год"       Binding="{Binding Year}"               Width="60"/>
                <DataGridTextColumn Header="Госномер"  Binding="{Binding Plate_Number}"       Width="110"/>
                <DataGridTextColumn Header="VIN"       Binding="{Binding VIN}"                Width="170"/>
                <DataGridTemplateColumn Header="Действия" Width="140" MinWidth="120">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,2">
                            <Button Content="Изменить" Style="{StaticResource PrimaryButton}"
                                    Padding="8,4" FontSize="12" Margin="0,0,4,0" Click="BtnEdit_Click"/>
                            <Button Content="Удалить" Style="{StaticResource DangerButton}"
                                    Padding="8,4" FontSize="12" Click="BtnDelete_Click"/>
                        </StackPanel>
                    </DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
