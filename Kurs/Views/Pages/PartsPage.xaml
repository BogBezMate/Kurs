<Page x:Class="Kurs.Views.Pages.PartsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F0F0">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="White" Padding="14,10"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Запчасти" Style="{StaticResource PageTitle}"/>
                    <TextBlock x:Name="TxtCount" FontSize="11" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Поступление" Style="{StaticResource SuccessButton}"
                            Height="28" Margin="0,0,6,0" Click="BtnReceive_Click"/>
                    <Button Content="Списание" Style="{StaticResource WarningButton}"
                            Height="28" Margin="0,0,6,0" Click="BtnWriteOff_Click"/>
                    <Button Content="Добавить" Style="{StaticResource PrimaryButton}"
                            Height="28" Click="BtnAdd_Click"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border DockPanel.Dock="Top" Background="White" Padding="14,8"
                BorderBrush="#CCCCCC" BorderThickness="0,0,0,1">
            <TextBox x:Name="TxtSearch" Style="{StaticResource ModernTextBox}"
                     Height="26" MaxWidth="320" HorizontalAlignment="Left"
                     TextChanged="TxtSearch_TextChanged"/>
        </Border>
        <DataGrid x:Name="GridParts" Style="{StaticResource ModernGrid}" Margin="12">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Quantity}" Value="0">
                            <Setter Property="Background" Value="#FFE0E0"/>
                            <Setter Property="Foreground" Value="#AA0000"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"            Binding="{Binding ID_Parts}"                         Width="50"/>
                <DataGridTextColumn Header="Наименование"  Binding="{Binding Name}"                             Width="*"/>
                <DataGridTextColumn Header="Поставщик"     Binding="{Binding Supplier.Name}"                    Width="180"/>
                <DataGridTextColumn Header="Остаток"       Binding="{Binding Quantity}"                         Width="80"/>
                <DataGridTextColumn Header="Цена"          Binding="{Binding Price, StringFormat={}{0:N2} ₽}"   Width="110"/>
                <DataGridTemplateColumn Header="Действия" Width="140" MinWidth="120">
                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="4,2">
                            <Button Content="Изменить" Style="{StaticResource PrimaryButton}"
                                    Padding="8,4" FontSize="12" Margin="0,0,4,0" Click="BtnEdit_Click"/>
                            <Button Content="Удалить" Style="{StaticResource DangerButton}"
                                    Padding="8,4" FontSize="12" Click="BtnDelete_Click"/>
                        </StackPanel>
                    </DataTemplate></DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
