<Window x:Class="Kurs.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="СТО — Управление автосервисом"
        MinHeight="500" MinWidth="800"
        Height="680" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <DockPanel Grid.Column="0" Background="#2B4C7E">
            <!-- Лого -->
            <Border DockPanel.Dock="Top" Padding="14,14,14,12"
                    BorderBrush="#1E3A6A" BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="СТО" FontSize="18" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="TxtCurrentUser" FontSize="11"
                               Foreground="#8AAAD0" Margin="0,4,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Выход -->
            <Border DockPanel.Dock="Bottom" BorderBrush="#1E3A6A" BorderThickness="0,1,0,0">
                <Button Style="{StaticResource SidebarButton}" Click="BtnLogout_Click"
                        Content="Выход" Padding="16,10"/>
            </Border>

            <!-- Меню -->
            <StackPanel Margin="0,8,0,0">
                <TextBlock Text="Справочники" FontSize="10" Foreground="#5A7AAA"
                           Margin="16,8,0,2" FontWeight="SemiBold"/>
                <Button x:Name="BtnEmployees" Content="Сотрудники"
                        Style="{StaticResource SidebarButton}"
                        Click="NavButton_Click" Tag="Employees"/>
                <Button x:Name="BtnCustomers" Content="Клиенты"
                        Style="{StaticResource SidebarButton}"
                        Click="NavButton_Click" Tag="Customers"/>
                <Button x:Name="BtnVehicles" Content="Автомобили"
                        Style="{StaticResource SidebarButton}"
                        Click="NavButton_Click" Tag="Vehicles"/>
                <Button x:Name="BtnSuppliers" Content="Поставщики"
                        Style="{StaticResource SidebarButton}"
                        Click="NavButton_Click" Tag="Suppliers"/>

                <TextBlock Text="Склад" FontSize="10" Foreground="#5A7AAA"
                           Margin="16,14,0,2" FontWeight="SemiBold"/>
                <Button x:Name="BtnParts" Content="Запчасти"
                        Style="{StaticResource SidebarButton}"
                        Click="NavButton_Click" Tag="Parts"/>

                <TextBlock Text="Работа" FontSize="10" Foreground="#5A7AAA"
                           Margin="16,14,0,2" FontWeight="SemiBold"/>
                <Button x:Name="BtnWorkOrders" Content="Заказ-наряды"
                        Style="{StaticResource SidebarButton}"
                        Click="NavButton_Click" Tag="WorkOrders"/>
            </StackPanel>
        </DockPanel>

        <!-- Контент -->
        <Frame x:Name="MainFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden" Background="#F0F0F0"/>
    </Grid>
</Window>
